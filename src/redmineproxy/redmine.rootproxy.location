# Set /redmine path in installation script (git project docker-md at /dockerfiles/redmine/bin):

location /redmine/stylesheets {{
  include /etc/nginx/conf.d/modules/redmine.proxypass;
  expires max;
  add_header 'Cache-Control' 'public, immutable';
  access_log off;
  log_not_found off;
}}

location /redmine/javascripts {{
  include /etc/nginx/conf.d/modules/redmine.proxypass;
  expires max;
  add_header 'Cache-Control' 'public, immutable';
  access_log off;
  log_not_found off;
}}

location /redmine/images {{
  include /etc/nginx/conf.d/modules/redmine.proxypass;
  add_header 'Cache-Control' 'public,max-age=3600';
  access_log off;
  log_not_found off;
}}

location /redmine {{
  include /etc/nginx/conf.d/modules/redmine.proxypass;

  # Required for redmine websocket agents
  proxy_set_header   Connection        $connection_upgrade;
  proxy_set_header   Upgrade           $http_upgrade;

#  proxy_set_header   Host              $http_host;
  proxy_set_header   X-Real-IP         $remote_addr;
  # proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
  proxy_set_header   X-Forwarded-Proto $scheme;
  proxy_set_header   X-Forwarded-Prefix /redmine;
  proxy_max_temp_file_size 0;

  # Activer l'auth plugin
  auth_request      /auth/verifier_usager;
  auth_request_set  $auth_x_user_name  $upstream_http_x_user_name;
#  proxy_set_header  X-Forwarded-User  $auth_x_user_name;
  proxy_set_header  X-Remote-User $auth_x_user_name;

  #this is the maximum upload size
  client_max_body_size       10m;
  # client_body_buffer_size    128k;

  proxy_connect_timeout      90s;
  proxy_send_timeout         90s;
  proxy_read_timeout         90s;
  proxy_request_buffering    off; # Required for HTTP CLI commands

  # Note: component_base utilise limite taille fichier trop petite pour redmine
  include /etc/nginx/conf.d/component_proxyheaders.include;
  include /etc/nginx/conf.d/component_gzip.include;
}}
